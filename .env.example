# Supabase connection — required
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
# VAPID_PRIVATE_KEY goes in Supabase edge function secrets only (never in frontend .env)

# ── Asistente Técnico RAG (scripts de ingesta locales) ──────────────────────
# Supabase service role key (solo para scripts locales de ingesta, NUNCA en frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Voyage AI API key — registro gratis en https://www.voyageai.com
# Plan gratuito: 50M tokens/mes — suficiente para toda la ingesta inicial
VOYAGE_API_KEY=pa-your-voyage-api-key-here
